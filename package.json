{
  "name": "thinking",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "author": "Young <ly532265997@gmail.com>",
  "scripts": {
    "build": "turbo run build",
    "docs:build": "turbo run docs:build --filter=@thinking/docs",
    "docs:dev": "pnpm docs:generate && turbo run docs:dev --filter=@thinking/docs",
    "docs:generate": "tsx scripts/generate-docs.ts",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "test": "turbo run test"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@vainjs/eslint-config": "latest",
    "eslint": "^9.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.4",
    "prettier": "^3.6.2",
    "tsx": "^4.0.0",
    "turbo": "^2.9.6",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@10.0.0"
}
